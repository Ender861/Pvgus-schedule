<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ScheduleApp.Views.HomeworkPage"
             Title="Домашние задания">
    
    <Grid>
        <CollectionView x:Name="HomeworkListView"
                        SelectionMode="Single"
                        SelectionChanged="OnHomeworkSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5,2" Padding="10">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackLayout>
                                <Label Text="{Binding Subject}" 
                                       FontSize="16"
                                       FontAttributes="Bold"/>
                                <Label Text="{Binding Task}" 
                                       FontSize="14"/>
                                <Label Text="{Binding Deadline, StringFormat='Срок: {0:dd.MM.yyyy}'}" 
                                       FontSize="12"
                                       TextColor="Gray"/>
                            </StackLayout>
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding IsCompleted}"
                                      VerticalOptions="Center"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
