<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ScheduleApp.Views.SettingsPage"
             Title="Настройки">
    
    <ScrollView>
        <StackLayout Padding="20" Spacing="15">
            <Label Text="Ваша группа" 
                   FontSize="16"
                   FontAttributes="Bold"/>
            <Entry x:Name="GroupEntry"
                   Placeholder="Например: БЭ25"
                   Text="{Binding GroupId}"/>
            
            <Label Text="Расписание" 
                   FontSize="16"
                   FontAttributes="Bold"
                   Margin="0,20,0,0"/>
            <Button Text="Обновить расписание"
                    Clicked="OnUpdateScheduleClicked"
                    BackgroundColor="#512BD4"
                    TextColor="White"/>
            
            <Button Text="Очистить расписание"
                    Clicked="OnClearScheduleClicked"
                    BackgroundColor="#FF4136"
                    TextColor="White"/>
            
            <Label Text="О приложении" 
                   FontSize="16"
                   FontAttributes="Bold"
                   Margin="0,20,0,0"/>
            <Label Text="Расписание ПВГУС + Ежедневник\nВерсия 1.0"
                   FontSize="12"
                   TextColor="Gray"/>
        </StackLayout>
    </ScrollView>
</ContentPage>
